# AstraLabsAI key for the live-web search tool
ASTRALABS_API_KEY=sk_live_replace_me

# === LLM provider (any OpenAI-compatible endpoint) ===
# Set LLM_API_KEY + LLM_BASE_URL + LLM_MODEL to the provider you want to use.
# Always double-check the latest base URL on the provider's own docs.
#
# OpenAI         https://api.openai.com/v1                                 gpt-4o-mini
# xAI (Grok)     https://api.x.ai/v1                                       grok-2-latest
# Google Gemini  https://generativelanguage.googleapis.com/v1beta/openai   gemini-2.0-flash
# DeepSeek       https://api.deepseek.com                                  deepseek-chat
# Qwen           https://dashscope-intl.aliyuncs.com/compatible-mode/v1    qwen-plus
# Moonshot/Kimi  https://api.moonshot.cn/v1                                moonshot-v1-8k
# Anthropic Claude is NOT natively OpenAI-compatible — use a proxy like
# LiteLLM (https://docs.litellm.ai) and point LLM_BASE_URL at the proxy.

LLM_API_KEY=sk-replace_me
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
